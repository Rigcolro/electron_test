{
  "name": "electron-wechat-research-demo",
  "version": "1.0.0",
  "main": "dist-electron/main/index.js",
  "description": "仿企业微信基础聊天能力前置调研桌面端（Electron + Vue3）",
  "author": "Research Demo",
  "license": "MIT",
  "private": true,
  "type": "module",
  "keywords": [
    "electron",
    "vite",
    "vue3",
    "element-plus",
    "better-sqlite3"
  ],
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "better-sqlite3", "esbuild"]
  },
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:3344/"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "node scripts/release-prompt.mjs",
    "build:direct": "vue-tsc --noEmit && vite build && node scripts/clean-release.mjs && electron-builder",
    "build:vite": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.ts --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,vue,js,css,json,md}\"",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "electron-store": "^10.0.0",
    "element-plus": "^2.9.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.32.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.1.10"
  }
}
